@model VinhKhanhTourGuide.WebAdmin.Models.Poi

@{
    ViewData["Title"] = "Chỉnh sửa quán ăn";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="text-primary fw-bold"><i class="fas fa-edit"></i> Chỉnh sửa thông tin</h2>
    <a asp-action="Index" class="btn btn-outline-secondary"><i class="fas fa-arrow-left"></i> Quay lại danh sách</a>
</div>

<div class="card shadow-sm">
    <div class="card-body p-4">
        <form asp-action="Edit" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="ImageName" />

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Name" class="control-label">Tên quán ăn</label>
                    <input asp-for="Name" class="form-control" placeholder="VD: Ốc Oanh" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label class="control-label">Tải ảnh mới (Bỏ trống nếu giữ ảnh cũ)</label>
                    <input type="file" name="uploadFile" class="form-control" accept="image/*" />

                    @if (!string.IsNullOrEmpty(Model.ImageName))
                    {
                        <small class="text-muted mt-1 d-block">
                            <i class="fas fa-image"></i> Ảnh hiện tại: <strong>@Model.ImageName</strong>
                        </small>
                    }
                </div>

                <div class="col-md-6 mb-3">
                    <label asp-for="Latitude" class="control-label">Vĩ độ (Latitude)</label>
                    <input asp-for="Latitude" class="form-control" type="text" />
                    <span asp-validation-for="Latitude" class="text-danger"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label asp-for="Longitude" class="control-label">Kinh độ (Longitude)</label>
                    <input asp-for="Longitude" class="form-control" type="text" />
                    <span asp-validation-for="Longitude" class="text-danger"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label asp-for="GeofenceRadius" class="control-label">Bán kính Radar (mét)</label>
                    <input asp-for="GeofenceRadius" class="form-control" />
                    <span asp-validation-for="GeofenceRadius" class="text-danger"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label asp-for="Priority" class="control-label">Độ ưu tiên (1 là cao nhất)</label>
                    <input asp-for="Priority" class="form-control" />
                    <span asp-validation-for="Priority" class="text-danger"></span>
                </div>

                <div class="col-12 mb-4">
                    <label asp-for="Description_VN" class="control-label">Bài thuyết minh (Tiếng Việt)</label>
                    <textarea asp-for="Description_VN" class="form-control" rows="4" placeholder="Nhập bài review chi tiết..."></textarea>
                    <span asp-validation-for="Description_VN" class="text-danger"></span>
                </div>
            </div>

            <div class="text-end border-top pt-3 mt-2">
                <button type="submit" class="btn btn-primary px-5"><i class="fas fa-save"></i> Lưu thay đổi</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}