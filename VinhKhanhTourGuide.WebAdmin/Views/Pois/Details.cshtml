@model VinhKhanhTourGuide.WebAdmin.Models.Poi

@{
    ViewData["Title"] = "Chi tiết quán ăn";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="text-info fw-bold"><i class="fas fa-info-circle"></i> Chi tiết quán ăn</h2>
    <div>
        <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-warning"><i class="fas fa-edit"></i> Chỉnh sửa</a>
        <a asp-action="Index" class="btn btn-outline-secondary"><i class="fas fa-arrow-left"></i> Quay lại</a>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body p-4">
        <div class="row">
            <div class="col-md-5 text-center mb-4 mb-md-0">
                @if (!string.IsNullOrEmpty(Model.ImageName))
                {
                    <img src="~/images/@Model.ImageName" alt="@Model.Name" class="img-fluid rounded shadow" style="max-height: 350px; width: 100%; object-fit: cover;" />
                }
                else
                {
                    <div class="p-5 bg-light rounded border text-muted d-flex flex-column justify-content-center h-100" style="min-height: 250px;">
                        <i class="fas fa-image fa-3x mb-2"></i>
                        <span>Chưa có hình ảnh</span>
                    </div>
                }
                <h4 class="mt-3 fw-bold text-primary">@Model.Name</h4>
                <span class="badge bg-success fs-6">Độ ưu tiên: @Model.Priority</span>
            </div>

            <div class="col-md-7">
                <dl class="row mb-0">
                    <dt class="col-sm-4 text-muted">Mã quán (Id)</dt>
                    <dd class="col-sm-8 fw-bold">@Model.Id</dd>

                    <dt class="col-sm-4 text-muted">Tên file ảnh</dt>
                    <dd class="col-sm-8"><code>@Model.ImageName</code></dd>

                    <dt class="col-sm-4 text-muted">Vĩ độ (Latitude)</dt>
                    <dd class="col-sm-8">@Model.Latitude</dd>

                    <dt class="col-sm-4 text-muted">Kinh độ (Longitude)</dt>
                    <dd class="col-sm-8">@Model.Longitude</dd>

                    <dt class="col-sm-4 text-muted">Bán kính Radar</dt>
                    <dd class="col-sm-8">@Model.GeofenceRadius mét</dd>

                    <dt class="col-sm-12 text-muted mt-3">Bài thuyết minh (Tiếng Việt)</dt>
                    <dd class="col-sm-12">
                        <div class="p-3 bg-light rounded border-start border-4 border-info">
                            @Model.Description_VN
                        </div>
                    </dd>
                </dl>
            </div>
        </div>
    </div>
</div>