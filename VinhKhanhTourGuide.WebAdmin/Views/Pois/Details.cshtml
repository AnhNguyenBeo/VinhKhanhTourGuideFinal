@model VinhKhanhTourGuide.WebAdmin.Models.Poi

@{
    ViewData["Title"] = "Chi tiết điểm đến";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="text-info fw-bold"><i class="fas fa-info-circle"></i> Chi tiết Quán ăn</h2>
    <div>
        <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-primary"><i class="fas fa-edit"></i> Chỉnh sửa</a>
        <a asp-action="Index" class="btn btn-outline-secondary"><i class="fas fa-arrow-left"></i> Quay lại</a>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-header bg-white border-bottom pt-4 pb-3">
        <h4 class="mb-0 text-primary">@Html.DisplayFor(model => model.Name)</h4>
    </div>
    <div class="card-body p-4">
        <dl class="row mb-0">
            <dt class="col-sm-3 text-muted mb-3">Mã định danh (ID)</dt>
            <dd class="col-sm-9 fw-bold mb-3">@Html.DisplayFor(model => model.Id)</dd>

            <dt class="col-sm-3 text-muted mb-3">Hình ảnh</dt>
            <dd class="col-sm-9 mb-3"><span class="badge bg-secondary">@Html.DisplayFor(model => model.ImageName)</span></dd>

            <dt class="col-sm-3 text-muted mb-3">Tọa độ GPS</dt>
            <dd class="col-sm-9 mb-3">
                <i class="fas fa-map-marker-alt text-danger"></i>
                @Html.DisplayFor(model => model.Latitude), @Html.DisplayFor(model => model.Longitude)
            </dd>

            <dt class="col-sm-3 text-muted mb-3">Radar & Ưu tiên</dt>
            <dd class="col-sm-9 mb-3">
                Bán kính: <span class="badge bg-success">@Html.DisplayFor(model => model.GeofenceRadius)m</span> |
                Ưu tiên: <span class="badge bg-warning text-dark">Mức @Html.DisplayFor(model => model.Priority)</span>
            </dd>

            <dt class="col-sm-3 text-muted mb-0">Bài thuyết minh</dt>
            <dd class="col-sm-9 mb-0 bg-light p-3 rounded border">
                @Html.DisplayFor(model => model.Description_VN)
            </dd>
        </dl>
    </div>
</div>