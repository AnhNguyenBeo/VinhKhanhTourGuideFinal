@model VinhKhanhTourGuide.WebAdmin.Models.Poi

@{
    ViewData["Title"] = "Xóa quán ăn";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="text-danger fw-bold"><i class="fas fa-trash-alt"></i> Xóa Điểm đến</h2>
    <a asp-action="Index" class="btn btn-outline-secondary"><i class="fas fa-arrow-left"></i> Quay lại danh sách</a>
</div>

<div class="alert alert-danger shadow-sm border-0 border-start border-danger border-4 py-3">
    <h5 class="mb-1 text-danger fw-bold"><i class="fas fa-exclamation-triangle me-2"></i> Cảnh báo quan trọng!</h5>
    <p class="mb-0">Bạn có chắc chắn muốn xóa quán <strong>@Model.Name</strong> khỏi hệ thống không? Hành động này sẽ xóa dữ liệu vĩnh viễn khỏi máy chủ và có thể làm mất dữ liệu hiển thị trên App của khách du lịch.</p>
</div>

<div class="card shadow-sm border-danger mt-4">
    <div class="card-header bg-white border-bottom pt-4 pb-3">
        <h4 class="mb-0 text-danger"><i class="fas fa-info-circle me-2"></i> Thông tin dữ liệu sẽ bị xóa</h4>
    </div>

    <div class="card-body p-4">
        <dl class="row mb-0">
            <dt class="col-sm-3 text-muted mb-3">Mã định danh (ID)</dt>
            <dd class="col-sm-9 fw-bold mb-3">@Html.DisplayFor(model => model.Id)</dd>

            <dt class="col-sm-3 text-muted mb-3">Tên quán ăn</dt>
            <dd class="col-sm-9 fw-bold text-primary mb-3">@Html.DisplayFor(model => model.Name)</dd>

            <dt class="col-sm-3 text-muted mb-3">Hình ảnh</dt>
            <dd class="col-sm-9 mb-3"><span class="badge bg-secondary">@Html.DisplayFor(model => model.ImageName)</span></dd>

            <dt class="col-sm-3 text-muted mb-3">Tọa độ GPS</dt>
            <dd class="col-sm-9 mb-3">
                <i class="fas fa-map-marker-alt text-danger me-1"></i>
                @Html.DisplayFor(model => model.Latitude), @Html.DisplayFor(model => model.Longitude)
            </dd>

            <dt class="col-sm-3 text-muted mb-3">Radar & Ưu tiên</dt>
            <dd class="col-sm-9 mb-3">
                Bán kính: <span class="badge bg-success">@Html.DisplayFor(model => model.GeofenceRadius)m</span> |
                Ưu tiên: <span class="badge bg-warning text-dark">Mức @Html.DisplayFor(model => model.Priority)</span>
            </dd>
        </dl>
    </div>

    <div class="card-footer bg-light p-3 text-end border-top-0">
        <form asp-action="Delete">
            <input type="hidden" asp-for="Id" />
            <a asp-action="Index" class="btn btn-outline-secondary me-2"><i class="fas fa-times"></i> Hủy bỏ</a>
            <button type="submit" class="btn btn-danger px-4 fw-bold shadow-sm">
                <i class="fas fa-trash me-2"></i> Xác nhận Xóa vĩnh viễn
            </button>
        </form>
    </div>
</div>