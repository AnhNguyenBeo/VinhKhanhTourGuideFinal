@model VinhKhanhTourGuide.WebAdmin.Models.Poi

@{
    ViewData["Title"] = "Thêm mới quán ăn";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="text-success fw-bold"><i class="fas fa-plus-circle"></i> Thêm quán ăn mới</h2>
    <a asp-action="Index" class="btn btn-outline-secondary"><i class="fas fa-arrow-left"></i> Quay lại danh sách</a>
</div>

<div class="card shadow-sm">
    <div class="card-body p-4">
        <form asp-action="Create" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Id" class="control-label">Mã quán (Id)</label>
                    <input asp-for="Id" class="form-control" placeholder="VD: OC-DAO" />
                    <span asp-validation-for="Id" class="text-danger"></span>
                    <small class="text-muted">Nhập mã viết liền, không dấu (Dùng để định danh hệ thống).</small>
                </div>

                <div class="col-md-6 mb-3">
                    <label asp-for="Name" class="control-label">Tên quán ăn</label>
                    <input asp-for="Name" class="form-control" placeholder="VD: Ốc Đào" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label class="control-label">Chọn ảnh quán ăn</label>
                    <input type="file" name="uploadFile" class="form-control" accept="image/*" required />
                    <span class="text-info small">Lưu ý: Nên chọn ảnh tỉ lệ 4:3 hoặc 16:9 để app hiển thị đẹp nhất.</span>
                </div>

                <div class="col-md-6 mb-3">
                    <label asp-for="Priority" class="control-label">Độ ưu tiên (1 là cao nhất)</label>
                    <input asp-for="Priority" class="form-control" type="number" value="1" />
                    <span asp-validation-for="Priority" class="text-danger"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label asp-for="Latitude" class="control-label">Vĩ độ (Latitude)</label>
                    <input asp-for="Latitude" class="form-control" type="text" placeholder="VD: 10.762..." />
                    <span asp-validation-for="Latitude" class="text-danger"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label asp-for="Longitude" class="control-label">Kinh độ (Longitude)</label>
                    <input asp-for="Longitude" class="form-control" type="text" placeholder="VD: 106.701..." />
                    <span asp-validation-for="Longitude" class="text-danger"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label asp-for="GeofenceRadius" class="control-label">Bán kính Radar (mét)</label>
                    <input asp-for="GeofenceRadius" class="form-control" value="30" />
                    <span asp-validation-for="GeofenceRadius" class="text-danger"></span>
                </div>

                <div class="col-12 mb-4">
                    <label asp-for="Description_VN" class="control-label">Bài thuyết minh (Tiếng Việt)</label>
                    <textarea asp-for="Description_VN" class="form-control" rows="5" placeholder="Nhập mô tả chi tiết về quán ăn, món đặc sản..."></textarea>
                    <span asp-validation-for="Description_VN" class="text-danger"></span>
                </div>
            </div>

            <div class="text-end border-top pt-3 mt-2">
                <button type="submit" class="btn btn-success px-5"><i class="fas fa-plus"></i> Tạo mới ngay</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}