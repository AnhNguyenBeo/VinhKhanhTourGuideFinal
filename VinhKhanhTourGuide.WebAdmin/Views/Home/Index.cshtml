@{
    ViewData["Title"] = "Trang chủ Admin";
}

<div class="text-center py-5 mt-4">
    <div class="mb-4">
        <i class="fas fa-map-marked-alt text-primary" style="font-size: 5rem; text-shadow: 2px 2px 10px rgba(0,0,0,0.1);"></i>
    </div>
    <h1 class="display-4 fw-bold text-dark mb-3">Vinh Khánh Tour Guide</h1>
    <p class="lead text-muted mb-5">Hệ thống quản lý trung tâm - Thuyết minh tự động đa ngôn ngữ</p>

    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow-sm border-0 h-100 feature-card">
                <div class="card-body p-5">
                    <div class="bg-primary text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-4 shadow" style="width: 80px; height: 80px;">
                        <i class="fas fa-store fa-2x"></i>
                    </div>
                    <h3 class="fw-bold">Quản lý Quán ăn</h3>
                    <p class="text-muted mb-4">Cập nhật tọa độ GPS, nội dung bài thuyết minh và thông số Geofence Radar.</p>
                    <a asp-controller="Pois" asp-action="Index" class="btn btn-primary btn-lg px-4 rounded-pill shadow-sm">
                        Truy cập ngay <i class="fas fa-arrow-right ms-2"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .feature-card:hover { transform: translateY(-5px); transition: all 0.3s ease; }
</style>