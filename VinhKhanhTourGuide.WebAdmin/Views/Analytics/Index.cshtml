@model VinhKhanhTourGuide.WebAdmin.Models.AnalyticsDashboardViewModel
@{
    ViewData["Title"] = "Báo cáo phân tích dữ liệu";
}

<h2 class="mb-4 text-primary">📊 Phân tích dữ liệu nghe thuyết minh</h2>

@if (TempData["AnalyticsMessage"] is string analyticsMessage)
{
    <div class="alert alert-info shadow-sm" role="alert">
        @analyticsMessage
    </div>
}

<div class="row g-3 mb-4">
    <div class="col-lg-4">
        <div class="card shadow h-100 border-start border-success border-4">
            <div class="card-body">
                <div class="text-muted small mb-2">Ứng dụng đang hoạt động</div>
                <div id="activeUsersNow" class="display-5 fw-bold text-success">@Model.ActiveUsersNow</div>
                <div class="text-muted small">Đã nhận heartbeat trong @Model.ActiveWindowSeconds giây gần nhất</div>
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="card shadow h-100">
            <div class="card-header bg-white py-3">
                <div class="d-flex flex-wrap justify-content-between align-items-center gap-2">
                    <h6 class="m-0 font-weight-bold text-success">Khách đang hoạt động theo thời gian thực</h6>
                    <div class="d-flex flex-wrap align-items-center gap-2">
                        <div class="small text-muted">
                            Tự làm mới mỗi 5 giây
                            <span class="mx-1">|</span>
                            Cập nhật lúc:
                            <span id="snapshotGeneratedAt">@Model.SnapshotGeneratedAt.ToString("HH:mm:ss")</span>
                        </div>
                        <form method="post" action="@Url.Action("ClearActiveVisitors", "Analytics")" class="m-0">
                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                Xóa phiên đang hoạt động
                            </button>
                        </form>
                    </div>
                </div>
            </div>
            <div id="activeVisitorsSection" class="card-body">
                @if (Model.ActiveVisitors.Count == 0)
                {
                    <div class="text-muted">Chưa có heartbeat nào từ khách trong @Model.ActiveWindowSeconds giây gần nhất.</div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Phiên</th>
                                    <th>Trạng thái</th>
                                    <th>Quán gần nhất</th>
                                    <th class="text-end">Khoảng cách</th>
                                    <th>Đang nghe quán</th>
                                    <th>Lần ghi nhận cuối</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var visitor in Model.ActiveVisitors)
                                {
                                    <tr>
                                        <td><code>@visitor.AnonymousSessionId</code></td>
                                        <td>
                                            @if (visitor.Status == "listening")
                                            {
                                                <span class="badge bg-danger">Đang nghe</span>
                                            }
                                            else if (visitor.Status == "near_poi")
                                            {
                                                <span class="badge bg-warning text-dark">Gần quán</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-success">Đang mở app</span>
                                            }
                                        </td>
                                        <td>@(visitor.NearestPoiName ?? "-")</td>
                                        <td class="text-end">
                                            @(visitor.DistanceToNearestPoiMeters.HasValue
                                                ? $"{visitor.DistanceToNearestPoiMeters.Value} m"
                                                : "-")
                                        </td>
                                        <td>@(visitor.CurrentListeningPoiName ?? "-")</td>
                                        <td>@visitor.LastSeenAt.ToString("HH:mm:ss")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-8">
        <div class="card shadow mb-4">
            <div class="card-header py-3">
                <h6 class="m-0 font-weight-bold text-primary">Top quán ăn được nghe nhiều nhất</h6>
            </div>
            <div class="card-body">
                <canvas id="topPoisChart" height="120"></canvas>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow mb-4">
            <div class="card-header py-3">
                <h6 class="m-0 font-weight-bold text-primary">Chi tiết thời gian</h6>
            </div>
            <div class="card-body">
                <table class="table table-bordered">
                    <thead>
                        <tr>
                            <th>Tên quán</th>
                            <th>Lượt nghe</th>
                            <th>TB (giây)</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.PoiStats)
                        {
                            <tr>
                                <td>@item.PoiName</td>
                                <td><span class="badge bg-success">@item.TotalListens</span></td>
                                <td>@item.AverageDuration s</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="row mt-2">
    <div class="col-12">
        <div class="card shadow mb-4">
            <div class="card-header py-3">
                <h6 class="m-0 font-weight-bold text-danger">🔥 Bản đồ nhiệt: vị trí khách nghe thuyết minh</h6>
            </div>
            <div class="card-body p-0">
                <div id="heatmapContainer" style="height: 450px; width: 100%; border-radius: 0 0 5px 5px; z-index: 1;"></div>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script src="https://unpkg.com/leaflet.heat@0.2.0/dist/leaflet-heat.js"></script>

<script>
    var labels = @Html.Raw(Json.Serialize(Model.PoiStats.Select(m => m.PoiName)));
    var dataListens = @Html.Raw(Json.Serialize(Model.PoiStats.Select(m => m.TotalListens)));

    var ctx = document.getElementById('topPoisChart').getContext('2d');
    new Chart(ctx, {
        type: 'bar',
        data: {
            labels: labels,
            datasets: [{
                label: 'Số lượt nghe',
                data: dataListens,
                backgroundColor: 'rgba(54, 162, 235, 0.6)',
                borderColor: 'rgba(54, 162, 235, 1)',
                borderWidth: 1
            }]
        },
        options: {
            scales: {
                y: { beginAtZero: true, ticks: { stepSize: 1 } }
            }
        }
    });

    var map = L.map('heatmapContainer').setView([10.7610, 106.7030], 16);

    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '© OpenStreetMap contributors',
        maxZoom: 19
    }).addTo(map);

    var heatData = @Html.Raw(Model.HeatmapDataJson);

    if (heatData && heatData.length > 0) {
        L.heatLayer(heatData, {
            radius: 25,
            blur: 15,
            maxZoom: 17,
            gradient: { 0.4: 'blue', 0.65: 'lime', 1: 'red' }
        }).addTo(map);
    }

    const activeVisitorsSnapshotUrl = '@Url.Action("Snapshot", "Analytics")';
    const activeVisitorsRefreshIntervalMs = 5000;
    let activeWindowSeconds = @Model.ActiveWindowSeconds;

    function escapeHtml(value) {
        return String(value ?? '')
            .replaceAll('&', '&amp;')
            .replaceAll('<', '&lt;')
            .replaceAll('>', '&gt;')
            .replaceAll('"', '&quot;')
            .replaceAll("'", '&#39;');
    }

    function formatDistance(distance) {
        if (distance === null || distance === undefined) {
            return '-';
        }

        return `${distance} m`;
    }

    function formatLastSeen(value) {
        if (!value) {
            return '-';
        }

        const date = new Date(value);
        if (Number.isNaN(date.getTime())) {
            return '-';
        }

        return date.toLocaleTimeString('vi-VN', {
            hour: '2-digit',
            minute: '2-digit',
            second: '2-digit',
            hour12: false
        });
    }

    function getStatusBadge(status) {
        if (status === 'listening') {
            return '<span class="badge bg-danger">Đang nghe</span>';
        }

        if (status === 'near_poi') {
            return '<span class="badge bg-warning text-dark">Gần quán</span>';
        }

        return '<span class="badge bg-success">Đang mở app</span>';
    }

    function renderActiveVisitors(activeVisitors) {
        const section = document.getElementById('activeVisitorsSection');
        if (!section) {
            return;
        }

        if (!Array.isArray(activeVisitors) || activeVisitors.length === 0) {
            section.innerHTML = `<div class="text-muted">Chưa có heartbeat nào từ khách trong ${activeWindowSeconds} giây gần nhất.</div>`;
            return;
        }

        const rows = activeVisitors.map(visitor => `
            <tr>
                <td><code>${escapeHtml(visitor.anonymousSessionId ?? 'N/A')}</code></td>
                <td>${getStatusBadge(visitor.status)}</td>
                <td>${escapeHtml(visitor.nearestPoiName ?? '-')}</td>
                <td class="text-end">${escapeHtml(formatDistance(visitor.distanceToNearestPoiMeters))}</td>
                <td>${escapeHtml(visitor.currentListeningPoiName ?? '-')}</td>
                <td>${escapeHtml(formatLastSeen(visitor.lastSeenAt))}</td>
            </tr>
        `).join('');

        section.innerHTML = `
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Phiên</th>
                            <th>Trạng thái</th>
                            <th>Quán gần nhất</th>
                            <th class="text-end">Khoảng cách</th>
                            <th>Đang nghe quán</th>
                            <th>Lần ghi nhận cuối</th>
                        </tr>
                    </thead>
                    <tbody>${rows}</tbody>
                </table>
            </div>
        `;
    }

    async function refreshActiveVisitorsAsync() {
        try {
            const response = await fetch(activeVisitorsSnapshotUrl, {
                headers: {
                    'X-Requested-With': 'XMLHttpRequest'
                },
                cache: 'no-store'
            });

            if (!response.ok) {
                return;
            }

            const snapshot = await response.json();
            const activeUsersElement = document.getElementById('activeUsersNow');
            const snapshotGeneratedAtElement = document.getElementById('snapshotGeneratedAt');

            activeWindowSeconds = snapshot.activeWindowSeconds ?? activeWindowSeconds;

            if (activeUsersElement) {
                activeUsersElement.textContent = snapshot.activeUsersNow ?? '0';
            }

            if (snapshotGeneratedAtElement) {
                snapshotGeneratedAtElement.textContent = formatLastSeen(snapshot.snapshotGeneratedAt);
            }

            renderActiveVisitors(snapshot.activeVisitors);
        } catch {
            // Giữ nguyên dữ liệu cũ nếu snapshot tạm thời lỗi.
        }
    }

    window.setInterval(refreshActiveVisitorsAsync, activeVisitorsRefreshIntervalMs);
</script>
