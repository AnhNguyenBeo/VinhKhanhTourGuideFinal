@model IEnumerable<VinhKhanhTourGuide.WebAdmin.Models.Tour>

@{
    ViewData["Title"] = "Tours";
}

<h1>Tours</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">+ Tạo tour mới</a>
</p>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Id</th>
            <th>Code</th>
            <th>Name</th>
            <th>EstimatedMinutes</th>
            <th>IsActive</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.Code</td>
                <td>@item.Name</td>
                <td>@item.EstimatedMinutes</td>
                <td>@item.IsActive</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                    <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                    <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>