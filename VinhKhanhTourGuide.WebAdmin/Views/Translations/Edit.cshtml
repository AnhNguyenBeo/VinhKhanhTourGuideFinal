@model VinhKhanhTourGuide.WebAdmin.Models.TranslationEntry

<h2>Edit Translation</h2>

<form asp-action="Edit">
    <input type="hidden" asp-for="Id" />

    <div class="form-group">
        <label>POI</label>
        <select asp-for="PoiId" asp-items="ViewBag.PoiList" class="form-control"></select>
    </div>

    <div class="form-group">
        <label>Language</label>
        <input asp-for="LanguageCode" class="form-control" />
    </div>

    <div class="form-group">
        <label>Text</label>
        <textarea asp-for="TranslatedText" class="form-control"></textarea>
    </div>

    <div class="form-group">
        <label>Approved</label>
        <input asp-for="IsApproved" type="checkbox" />
    </div>

    <button class="btn btn-success">Update</button>
    <a asp-action="Index">Back</a>
</form>