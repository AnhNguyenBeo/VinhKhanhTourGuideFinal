<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VinhKhanhTourGuide.Views.EateryDetailPage"
             Title="{Binding Name}">

    <ScrollView>
        <VerticalStackLayout Spacing="15" Padding="20">
            <Image Source="{Binding ImageName}" 
                   HeightRequest="250" 
                   Aspect="AspectFill" />

            <Label Text="{Binding Name}" 
                   FontSize="26" 
                   FontAttributes="Bold" 
                   TextColor="Purple"/>

            <Label Text="{Binding Description_VN}" 
                   FontSize="16" 
                   LineHeight="1.5"
                   TextColor="Black" />

            <BoxView HeightRequest="1" Color="LightGray" Margin="0,10" />

            <HorizontalStackLayout Spacing="15" HorizontalOptions="Center">
                <Button x:Name="PlayAudioButton" 
                        Text="🔊 Nghe thuyết minh" 
                        Clicked="OnPlayAudioClicked" 
                        BackgroundColor="Purple" 
                        TextColor="White" 
                        CornerRadius="10"
                        HeightRequest="50"/>

                <Button x:Name="NavigateButton" 
                        Text="📍 Chỉ đường" 
                        Clicked="OnNavigateClicked" 
                        BackgroundColor="#1976D2" 
                        TextColor="White" 
                        CornerRadius="10"
                        HeightRequest="50"/>
            </HorizontalStackLayout>

            <Label x:Name="StatusLabel" 
                   Text="" 
                   TextColor="Gray" 
                   FontAttributes="Italic" 
                   HorizontalOptions="Center"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>