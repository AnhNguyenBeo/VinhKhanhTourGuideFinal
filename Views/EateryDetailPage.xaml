<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="VinhKhanhTourGuide.Views.EateryDetailPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="#F7F0E3"
    NavigationPage.HasNavigationBar="False">

    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <!-- hero image -->
            <Grid HeightRequest="260">
                <Image Source="{Binding ImageUrl}" 
                   HeightRequest="250" 
                   Aspect="AspectFill" />

                    <Grid>
                    <Grid.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#33000000" Offset="0.0" />
                            <GradientStop Color="#00000000" Offset="0.45" />
                            <GradientStop Color="#66000000" Offset="1.0" />
                        </LinearGradientBrush>
                    </Grid.Background>
                </Grid>

                <!-- close -->
                <Border BackgroundColor="#FDFDFD"
                        WidthRequest="40"
                        HeightRequest="40"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 20"
                        HorizontalOptions="Start"
                        VerticalOptions="Start"
                        Margin="16,16,0,0">
                    <Button Text="✕"
                            BackgroundColor="Transparent"
                            TextColor="#7C2D12"
                            FontSize="20"
                            Clicked="OnBackClicked" />
                </Border>
            </Grid>

            <!-- content -->
            <VerticalStackLayout Padding="28,24,28,30"
                                 Spacing="22">

                <VerticalStackLayout Spacing="12">
                    <Label Text="{Binding Name}"
                           TextColor="#7C2D12"
                           FontSize="28"
                           FontAttributes="Bold" />

                    <Label Text="{Binding Description_VN}"
                           TextColor="#8B4513"
                           FontSize="16"
                           LineHeight="1.5" />
                </VerticalStackLayout>

                <!-- Play narration -->
                <Button x:Name="PlayAudioButton"
                        Text="▶  Nghe thuyết minh"
                        BackgroundColor="#F97316"
                        TextColor="White"
                        FontSize="21"
                        FontAttributes="Bold"
                        CornerRadius="20"
                        HeightRequest="86"
                        Clicked="OnPlayAudioClicked" />

                <Button x:Name="StopAudioButton"
                        Text="⏹  Dừng đọc"
                        BackgroundColor="#EF4444"
                        TextColor="White"
                        FontSize="21"
                        FontAttributes="Bold"
                        CornerRadius="20"
                        HeightRequest="86"
                        IsVisible="False" 
                        Clicked="OnStopAudioClicked" />     

                <!-- Navigate -->
                <Button Text="➤  Chỉ đường"
                        BackgroundColor="White"
                        TextColor="#7C2D12"
                        FontSize="21"
                        FontAttributes="Bold"
                        CornerRadius="20"
                        BorderColor="#F3C38B"
                        BorderWidth="1.5"
                        HeightRequest="86"
                        Clicked="OnNavigateClicked" />

                <Label x:Name="StatusLabel"
                       Text=""
                       TextColor="#C2410C"
                       FontSize="14" />

                <BoxView WidthRequest="82"
                         HeightRequest="5"
                         CornerRadius="3"
                         Color="#F59E0B"
                         HorizontalOptions="Center"
                         Margin="0,10,0,0" />
            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>