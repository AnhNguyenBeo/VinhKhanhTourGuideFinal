<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="VinhKhanhTourGuide.Views.MapPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:maps="clr-namespace:Microsoft.Maui.Controls.Maps;assembly=Microsoft.Maui.Controls.Maps"
    xmlns:model="clr-namespace:VinhKhanhTourGuide.Models"
    BackgroundColor="#F7F0E3"
    NavigationPage.HasNavigationBar="False">

    <Grid>

        <Grid x:Name="MapContainer" ZIndex="0">
            <maps:Map
                x:Name="VinhKhanhMap"
                IsShowingUser="True"
                MapType="Street" />

            <VerticalStackLayout
                Padding="24,20,24,0"
                Spacing="14"
                VerticalOptions="Start"
                ZIndex="10"
                InputTransparent="False">

                <Border
                    x:Name="StatusPill"
                    BackgroundColor="#FCFCFB"
                    Stroke="#F3D8BF"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 28"
                    Padding="10,6"
                    HorizontalOptions="Center">
                    <HorizontalStackLayout
                        HorizontalOptions="Center"
                        Spacing="8">
                        <Label
                            Text="◎"
                            TextColor="#F97316"
                            FontSize="10"
                            VerticalOptions="Center" />
                        <Label
                            x:Name="GeofenceStatusLabel"
                            Text="Scanning nearby locations..."
                            TextColor="#7C2D12"
                            FontSize="14"
                            HorizontalTextAlignment="Center"
                            LineBreakMode="TailTruncation" />
                    </HorizontalStackLayout>
                </Border>

                <Border
                    x:Name="PremiumBanner"
                    IsVisible="False"
                    InputTransparent="False"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 12"
                    Padding="12,10"
                    HorizontalOptions="Center"
                    MaximumWidthRequest="320">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#FF5F00" Offset="0.0" />
                            <GradientStop Color="#FF8C00" Offset="0.6" />
                            <GradientStop Color="#FFD400" Offset="0.95" />
                        </LinearGradientBrush>
                    </Border.Background>

                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnPremiumBannerTapped" />
                    </Border.GestureRecognizers>

                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="14">
                        <VerticalStackLayout
                            Spacing="1"
                            VerticalOptions="Center">
                            <Label
                                Text="Mở khóa trải nghiệm"
                                TextColor="White"
                                FontSize="18"
                                FontAttributes="Bold" />
                            <Label
                                Text="Thuyết minh tự động cho mọi quán ăn"
                                TextColor="White"
                                FontSize="12"
                                FontAttributes="Bold" />
                        </VerticalStackLayout>

                        <Border
                            Grid.Column="1"
                            BackgroundColor="White"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 10"
                            Padding="8"
                            VerticalOptions="Center">
                            <Label
                                Text="10,000 VND"
                                TextColor="#EA580C"
                                FontSize="16"
                                FontAttributes="Bold" />
                        </Border>
                    </Grid>
                </Border>

            </VerticalStackLayout>

            <Border
                x:Name="NowPlayingCard"
                IsVisible="False"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 14"
                Padding="18,12,14,12"
                Margin="0,0,0,16"
                MaximumWidthRequest="300"
                HorizontalOptions="Center"
                VerticalOptions="End"
                ZIndex="15">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#FF5F00" Offset="0.0" />
                        <GradientStop Color="#FF8C00" Offset="0.7" />
                    </LinearGradientBrush>
                </Border.Background>

                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">

                    <HorizontalStackLayout
                        VerticalOptions="Center"
                        Spacing="2">
                        <BoxView
                            x:Name="Wave1"
                            WidthRequest="4"
                            HeightRequest="20"
                            CornerRadius="1"
                            Color="White"
                            VerticalOptions="End" />
                        <BoxView
                            x:Name="Wave2"
                            WidthRequest="4"
                            HeightRequest="28"
                            CornerRadius="1"
                            Color="White"
                            VerticalOptions="End" />
                        <BoxView
                            x:Name="Wave3"
                            WidthRequest="4"
                            HeightRequest="16"
                            CornerRadius="1"
                            Color="White"
                            VerticalOptions="End" />
                        <BoxView
                            x:Name="Wave4"
                            WidthRequest="4"
                            HeightRequest="26"
                            CornerRadius="1"
                            Color="White"
                            VerticalOptions="End" />
                    </HorizontalStackLayout>

                    <VerticalStackLayout
                        Grid.Column="1"
                        VerticalOptions="Center"
                        Spacing="1">
                        <Label
                            Text="Đang phát:"
                            TextColor="#FFEDD5"
                            FontAttributes="Bold"
                            FontSize="13" />
                        <Label
                            x:Name="NowPlayingNameLabel"
                            Text=""
                            TextColor="White"
                            FontSize="18"
                            FontAttributes="Bold"
                            LineBreakMode="TailTruncation" />
                    </VerticalStackLayout>

                    <Border
                        Grid.Column="2"
                        x:Name="StopAudioBtn"
                        WidthRequest="40"
                        HeightRequest="40"
                        BackgroundColor="#FFC300"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 50"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        IsVisible="False">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnStopAudioTapped" />
                        </Border.GestureRecognizers>

                        <Grid>
                            <BoxView
                                WidthRequest="18"
                                HeightRequest="18"
                                Color="White"
                                HorizontalOptions="Center"
                                VerticalOptions="Center" />
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <Border
            x:Name="BottomSheet"
            ZIndex="20"
            BackgroundColor="#FBF6EE"
            StrokeThickness="0"
            Padding="0"
            HeightRequest="620"
            VerticalOptions="End">

            <Grid RowDefinitions="2,Auto,Auto,*">

                <BoxView
                    Grid.Row="0"
                    Color="#F59E0B"
                    HeightRequest="2"
                    HorizontalOptions="Fill" />

                <Border
                    Grid.Row="1"
                    WidthRequest="52"
                    HeightRequest="6"
                    BackgroundColor="#FF8C00"
                    StrokeThickness="0"
                    HorizontalOptions="Center"
                    Margin="0,10,0,14">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="30" />
                    </Border.StrokeShape>

                    <Border.GestureRecognizers>
                        <PanGestureRecognizer PanUpdated="OnBottomSheetPanUpdated" />
                    </Border.GestureRecognizers>
                </Border>

                <VerticalStackLayout
                    Grid.Row="2"
                    Padding="26,0,26,14"
                    Spacing="4">
                    <Label
                        Text="QUÁN ĂN GẦN BẠN"
                        TextColor="#7C2D12"
                        FontSize="22"
                        FontAttributes="Bold" />
                    <Label
                        x:Name="LocationCountLabel"
                        Text="Đang tìm quán ăn..."
                        TextColor="#C2410C"
                        FontSize="14" />
                </VerticalStackLayout>

                <CollectionView
                    x:Name="EateryList"
                    Grid.Row="3"
                    SelectionChanged="OnEaterySelected"
                    SelectionMode="Single"
                    Margin="0,0,0,10"
                    BackgroundColor="#FBF6EE"
                    VerticalOptions="Fill"
                    ItemsLayout="VerticalList">

                    <CollectionView.Footer>
                        <BoxView HeightRequest="320" BackgroundColor="Transparent" />
                    </CollectionView.Footer>

                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="model:Poi">
                            <Border
                                Margin="26,8"
                                Padding="14"
                                BackgroundColor="White"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 12">

                                <Grid ColumnDefinitions="82,*,Auto" ColumnSpacing="14">

                                    <Grid
                                        WidthRequest="82"
                                        HeightRequest="82">
                                        <Border
                                            BackgroundColor="#F4E1C7"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 18" />
                                        <Image Source="{Binding ImageUrl}"
                                            Aspect="AspectFill" />
                                    </Grid>

                                    <VerticalStackLayout
                                        Grid.Column="1"
                                        VerticalOptions="Center"
                                        Spacing="4">
                                        <Label
                                            Text="{Binding Name}"
                                            TextColor="#7C2D12"
                                            FontSize="18"
                                            FontAttributes="Bold"
                                            LineBreakMode="TailTruncation" />
                                        <HorizontalStackLayout Spacing="5">
                                            <Label
                                                Text="📍"
                                                FontSize="13"
                                                TextColor="#F97316" />
                                            <Label Text="{Binding DistanceText}"
                                                    FontSize="14"
                                                    TextColor="#F97316" />
                                        </HorizontalStackLayout>
                                    </VerticalStackLayout>

                                    <Border
                                        Grid.Column="2"
                                        WidthRequest="10"
                                        HeightRequest="10"
                                        BackgroundColor="#F97316"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 50"
                                        HorizontalOptions="Center"
                                        VerticalOptions="Center" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Grid>
        </Border>
    </Grid>
</ContentPage>