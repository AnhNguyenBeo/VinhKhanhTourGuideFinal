<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VinhKhanhTourGuide.Views.MapPage"
             Title="Smart Map (POC)">

    <VerticalStackLayout Spacing="20" Padding="20" VerticalOptions="Center">
        <Label Text="Giả lập Geofencing (POC)"
               FontSize="24"
               FontAttributes="Bold"
               HorizontalOptions="Center" />

        <Label x:Name="StatusLabel"
               Text="Trạng thái: Đang chờ vị trí..."
               HorizontalOptions="Center" />

        <Button Text="Đóng giả khách đi tới quán Ốc Oanh"
                Clicked="OnTriggerOcOanhClicked"
                BackgroundColor="#28a745"
                TextColor="White"
                CornerRadius="10"
                HorizontalOptions="Center" />
    </VerticalStackLayout>
</ContentPage>